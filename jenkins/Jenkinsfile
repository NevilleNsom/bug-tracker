pipeline {
    agent any

    stages {
        stage ('Running test in parrelel'){
            parallel {
                 stage('Running back-end unit tests') {
            agent {
                docker {
                    image 'snakee/golang-junit:1.21'
                    reuseNode true
                }
           }
            steps {
               dir('bugtracker-backend'){
                sh 'go test -v ./...'
               }
               
            }
        }
        stage('Running front-end unit tests') {
            agent {
                docker {
                    image 'node:20-alpine'
                    reuseNode true
                }
            }
            steps {
                dir('bugtracker-frontend'){
                        sh '''
                    npm ci
                    npm test
                '''
                }
            
               } 
             }
         }
       
            //This is to generate a report on jenkins, it is not complete 
            //It lacks an auto generated file from local tests run
            //post {
                //always {
                    //junit ''
                //}
            //}
        }
    
    }

    post {
        always{
            cleanWs()
        }
    }
}
